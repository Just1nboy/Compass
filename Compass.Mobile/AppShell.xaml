<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Compass.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Compass.Mobile.Pages"
    Title="Compass"
    FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="#11151C"
    Shell.TabBarForegroundColor="#4F8CFF"
    Shell.TabBarTitleColor="#4F8CFF"
    Shell.TabBarUnselectedColor="#9AA7B8">

    <TabBar>
        <ShellContent Title="Today" Icon="today.png" ContentTemplate="{DataTemplate pages:TodayPage}" Route="today" />
        <ShellContent Title="Deadlines" Icon="deadlines.png" ContentTemplate="{DataTemplate pages:DeadlinesPage}" Route="deadlines" />
        <ShellContent Title="Playbooks" Icon="playbooks.png" ContentTemplate="{DataTemplate pages:PlaybooksPage}" Route="playbooks" />
        <ShellContent Title="Inbox" Icon="inbox.png" ContentTemplate="{DataTemplate pages:InboxPage}" Route="inbox" />
        <ShellContent Title="Sync" Icon="sync.png" ContentTemplate="{DataTemplate pages:SyncPage}" Route="sync" />
    </TabBar>

</Shell>
