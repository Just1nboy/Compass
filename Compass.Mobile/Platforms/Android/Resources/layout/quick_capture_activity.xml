<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#11151C"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quick capture"
        android:textColor="#F2F5F9"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="10dp" />

    <EditText
        android:id="@+id/captureInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Type it down…"
        android:textColor="#F2F5F9"
        android:textColorHint="#9AA7B8"
        android:textSize="16sp"
        android:background="#232B36"
        android:padding="14dp"
        android:minLines="4"
        android:gravity="top"
        android:inputType="textMultiLine|textCapSentences" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="14dp">

        <Button
            android:id="@+id/cancelBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#F2F5F9"
            android:background="@android:color/transparent" />

        <Button
            android:id="@+id/saveBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4F8CFF"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
