<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Compass.Mobile.Pages.InboxPage"
             Title="Inbox"
             BackgroundColor="{StaticResource Bg}">
    <RefreshView x:Name="Refresh" Refreshing="Refresh_Refreshing" RefreshColor="{StaticResource Accent}">
    <ScrollView>
        <VerticalStackLayout Padding="18,16" Spacing="12">
            <Label Text="Capture inbox" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextC}" />
            <Label Text="Dump anything here the second you hear it, so it never lives only in your head."
                   FontSize="13" TextColor="{StaticResource Muted}" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry x:Name="Box" Placeholder="Type and tap Add"
                       TextColor="{StaticResource TextC}" PlaceholderColor="{StaticResource Muted}"
                       BackgroundColor="{StaticResource Surface2}" />
                <Button Grid.Column="1" Text="Add" Clicked="Add_Clicked"
                        BackgroundColor="{StaticResource Accent}" TextColor="White" CornerRadius="8" />
            </Grid>

            <VerticalStackLayout x:Name="ListPanel" Spacing="8" />
        </VerticalStackLayout>
    </ScrollView>
    </RefreshView>
</ContentPage>
