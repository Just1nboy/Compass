<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Compass.Mobile.Pages.DeadlinesPage"
             Title="Deadlines"
             BackgroundColor="{StaticResource Bg}">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="＋ Add" Clicked="Add_Clicked" />
    </ContentPage.ToolbarItems>
    <RefreshView x:Name="Refresh" Refreshing="Refresh_Refreshing" RefreshColor="{StaticResource Accent}">
    <ScrollView>
        <VerticalStackLayout Padding="18,16" Spacing="10">
            <Button Text="＋  Add deadline" Clicked="Add_Clicked"
                    BackgroundColor="{StaticResource Accent}" TextColor="White" CornerRadius="10" />

            <Label Text="Active" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextC}" Margin="0,6,0,0" />
            <VerticalStackLayout x:Name="ActivePanel" Spacing="8" />

            <Label x:Name="DoneHeader" Text="Completed" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource Muted}" Margin="0,10,0,0" />
            <VerticalStackLayout x:Name="DonePanel" Spacing="8" />
        </VerticalStackLayout>
    </ScrollView>
    </RefreshView>
</ContentPage>
