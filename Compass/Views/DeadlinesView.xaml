<UserControl x:Class="Compass.Views.DeadlinesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,26,30,30" MaxWidth="840" HorizontalAlignment="Left">

            <DockPanel Margin="0,0,0,20">
                <Button DockPanel.Dock="Right" Content="＋  Add deadline" Style="{StaticResource Primary}" Click="Add_Click"/>
                <StackPanel>
                    <TextBlock Text="Deadlines" Foreground="{StaticResource Text}" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Everything you're tracking, soonest first." Foreground="{StaticResource Muted}" FontSize="14" Margin="0,3,0,0"/>
                </StackPanel>
            </DockPanel>

            <TextBlock x:Name="ActiveHeader" Text="Active" Foreground="{StaticResource Text}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <StackPanel x:Name="ActivePanel"/>

            <TextBlock x:Name="DoneHeader" Text="Completed" Foreground="{StaticResource Muted}" FontSize="15" FontWeight="SemiBold" Margin="0,18,0,12"/>
            <StackPanel x:Name="DonePanel"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
