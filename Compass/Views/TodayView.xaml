<UserControl x:Class="Compass.Views.TodayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
        <StackPanel Margin="30,26,30,30" MaxWidth="840" HorizontalAlignment="Left">

            <TextBlock x:Name="Greeting" Foreground="{StaticResource Text}" FontSize="24" FontWeight="Bold"/>
            <TextBlock x:Name="TodayDate" Foreground="{StaticResource Muted}" FontSize="15" Margin="0,3,0,20"/>

            <!-- Quick capture -->
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="Quick capture — dump it here the second you hear it" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,8"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Add" Style="{StaticResource Primary}" Margin="10,0,0,0" Click="Capture_Click"/>
                        <TextBox x:Name="CaptureBox" FontSize="14" Padding="10,8" MinHeight="38"
                                 VerticalContentAlignment="Center" KeyDown="CaptureBox_KeyDown"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="⚠  Needs your attention" Foreground="{StaticResource Text}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <StackPanel x:Name="AttentionPanel"/>

            <TextBlock Text="📅  Coming up (next 2 weeks)" Foreground="{StaticResource Text}" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,12"/>
            <StackPanel x:Name="UpcomingPanel"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
