<UserControl x:Class="Compass.Views.PlaybooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,26,30,30" MaxWidth="880" HorizontalAlignment="Left">
            <TextBlock Text="Playbooks" Foreground="{StaticResource Text}" FontSize="24" FontWeight="Bold"/>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="14" Margin="0,3,0,20"
                       Text="The app knows the steps so you don't have to. Each step also tells you the exact question to ask and where to get the answer — so you stop getting blindsided by things you didn't know to ask."/>
            <StackPanel x:Name="Root"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
