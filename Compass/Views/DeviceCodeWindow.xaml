<Window x:Class="Compass.Views.DeviceCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign in to BINUS (Microsoft)" Height="330" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Bg}" FontFamily="Segoe UI">
    <StackPanel Margin="22">
        <TextBlock Text="Sign in to your BINUS account" Foreground="{StaticResource Text}" FontSize="18" FontWeight="Bold"/>
        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="13" Margin="0,6,0,12"
                   Text="Open the sign-in page, enter the code below, and log in with your @binus.ac.id account. Keep this window open until it finishes."/>
        <TextBox x:Name="MessageBox" IsReadOnly="True" TextWrapping="Wrap" FontSize="13"
                 Padding="10,8" MinHeight="90" Background="White"/>
        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
            <Button Content="Open sign-in page" Style="{StaticResource Primary}" Click="Open_Click"/>
            <Button x:Name="CopyBtn" Content="Copy code" Style="{StaticResource Ghost}" Margin="10,0,0,0" Click="Copy_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
