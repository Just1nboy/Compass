<UserControl x:Class="Compass.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,26,30,30" MaxWidth="860" HorizontalAlignment="Left">

            <TextBlock Text="Settings" Foreground="{StaticResource Text}" FontSize="24" FontWeight="Bold" Margin="0,0,0,18"/>

            <!-- Sync with phone -->
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="12" Padding="18,16" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Sync with your phone" Foreground="{StaticResource Text}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SyncStatus" Foreground="{StaticResource Muted}" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,10"/>

                    <StackPanel x:Name="SyncSignedOutPanel">
                        <TextBlock Text="Sign in with the same email on your PC and phone to share your deadlines." Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,8"/>
                        <TextBox x:Name="SyncEmailBox" FontSize="13" Padding="10,7" MinHeight="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="SyncPwBox" FontSize="13" Padding="10,7" MinHeight="34" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="SignInBtn" Content="Sign in" Style="{StaticResource Primary}" Margin="0,0,8,0" Click="SignIn_Click"/>
                            <Button Content="Create account" Style="{StaticResource Ghost}" Click="CreateAccount_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="SyncSignedInPanel" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Sync now" Style="{StaticResource Primary}" Margin="0,0,8,0" Click="SyncNow_Click"/>
                            <Button Content="Sign out" Style="{StaticResource Ghost}" Click="SignOut_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="LastSyncLbl" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,10,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AI -->
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="12" Padding="18,16" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="AI assistant" Foreground="{StaticResource Text}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ClaudeStatus" Foreground="{StaticResource Muted}" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Model" Foreground="{StaticResource Muted}" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="ModelBox" Width="160" Height="32" FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Email accounts -->
            <TextBlock Text="Email accounts" Foreground="{StaticResource Text}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <StackPanel x:Name="AccountsPanel"/>

            <!-- Import -->
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="12" Padding="18,16" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="Import deadlines from email" Foreground="{StaticResource Text}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{StaticResource Muted}" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,10"
                               Text="Scans your enabled accounts, uses AI to find real dates, and lets you confirm each one before it's added."/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Scan the last" Foreground="{StaticResource Muted}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="DaysBox" Width="90" Height="32" FontSize="13"/>
                        <TextBlock Text="of email" Foreground="{StaticResource Muted}" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ImportBtn" Content="Import now" Style="{StaticResource Primary}" Click="Import_Click"/>
                        <TextBlock x:Name="ImportStatus" Foreground="{StaticResource Muted}" FontSize="13" VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:Name="LastImportLbl" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
