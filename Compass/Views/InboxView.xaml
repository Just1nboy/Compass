<UserControl x:Class="Compass.Views.InboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,26,30,30" MaxWidth="840" HorizontalAlignment="Left">
            <TextBlock Text="Capture inbox" Foreground="{StaticResource Text}" FontSize="24" FontWeight="Bold"/>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="14" Margin="0,3,0,18"
                       Text="Anything you hear — a date, a task, a 'wait, what was that?' — dump it here now so it never lives only in your head. Turn it into a real deadline later."/>

            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,20">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Add" Style="{StaticResource Primary}" Margin="10,0,0,0" Click="Add_Click"/>
                    <TextBox x:Name="Box" FontSize="14" Padding="10,8" MinHeight="38" VerticalContentAlignment="Center" KeyDown="Box_KeyDown"/>
                </DockPanel>
            </Border>

            <StackPanel x:Name="ListPanel"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
