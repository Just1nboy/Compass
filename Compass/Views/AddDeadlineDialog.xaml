<Window x:Class="Compass.Views.AddDeadlineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add a deadline" Height="740" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,22,24,22">

            <TextBlock Text="Add a deadline" Foreground="{StaticResource Text}" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="You'll confirm the date &amp; time at the bottom before saving." Foreground="{StaticResource Muted}" FontSize="12" Margin="0,2,0,18"/>

            <TextBlock Text="What is it?" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="TitleBox" FontSize="15" Padding="10,8" MinHeight="38" VerticalContentAlignment="Center"/>

            <TextBlock Text="Type" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,14,0,5"/>
            <ComboBox x:Name="KindBox" FontSize="14" Padding="8,6" Height="34"/>

            <TextBlock Text="Date" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,14,0,5"/>
            <DatePicker x:Name="DateBox" FontSize="14" Height="34"/>

            <TextBlock Text="Time" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,14,0,5"/>
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="HourBox" Width="70" Height="34" FontSize="14"/>
                <TextBlock Text=":" Foreground="{StaticResource Text}" FontSize="18" VerticalAlignment="Center" Margin="8,0,8,0"/>
                <ComboBox x:Name="MinBox" Width="70" Height="34" FontSize="14"/>
                <ComboBox x:Name="AmPmBox" Width="70" Height="34" FontSize="14" Margin="10,0,0,0"/>
            </StackPanel>

            <TextBlock Text="Start reminding me to prepare" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,14,0,5"/>
            <ComboBox x:Name="PrepBox" FontSize="14" Padding="8,6" Height="34"/>

            <CheckBox x:Name="CriticalBox" Margin="0,16,0,0">
                <TextBlock Text="Critical — keep nagging me until I acknowledge it (use for exams!)" Foreground="{StaticResource Text}" FontSize="13" TextWrapping="Wrap"/>
            </CheckBox>

            <TextBlock Text="Where can you double-check this? (office, website, who to ask)" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,16,0,5"/>
            <TextBox x:Name="WhereBox" FontSize="13" Padding="10,8" MinHeight="36" VerticalContentAlignment="Center"/>

            <TextBlock Text="Notes (optional)" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,14,0,5"/>
            <TextBox x:Name="NotesBox" FontSize="13" Padding="10,8" MinHeight="56" TextWrapping="Wrap" AcceptsReturn="True"/>

            <!-- Read-back verification -->
            <Border Background="{StaticResource Surface2}" BorderBrush="{StaticResource Accent}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="CHECK THIS CAREFULLY" Foreground="{StaticResource Accent}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock x:Name="Preview" Foreground="{StaticResource Text}" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    <TextBlock x:Name="PreviewCountdown" Foreground="{StaticResource Accent}" FontSize="13" FontWeight="Bold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <CheckBox x:Name="ConfirmBox" Margin="0,14,0,0" Checked="Confirm_Changed" Unchecked="Confirm_Changed">
                <TextBlock Text="Yes — I've read the line above and the day and time are correct." Foreground="{StaticResource Text}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </CheckBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Style="{StaticResource Ghost}" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button x:Name="SaveBtn" Content="Save deadline" Style="{StaticResource Primary}" IsEnabled="False" Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
