<Window x:Class="Compass.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compass" Height="660" Width="960"
        MinHeight="540" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
            <DockPanel Margin="14,18,14,14">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="🧭  Compass" Foreground="{StaticResource Text}" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="never miss what matters" Foreground="{StaticResource Muted}" FontSize="12" Margin="2,2,0,18"/>

                    <Button x:Name="NavToday" Style="{StaticResource Nav}" Content="🏠   Today" Click="NavToday_Click"/>
                    <Button x:Name="NavDeadlines" Style="{StaticResource Nav}" Content="📅   Deadlines" Click="NavDeadlines_Click"/>
                    <Button x:Name="NavAssistant" Style="{StaticResource Nav}" Content="✨   What am I missing?" Click="NavAssistant_Click"/>
                    <Button x:Name="NavPlaybooks" Style="{StaticResource Nav}" Content="📖   Playbooks" Click="NavPlaybooks_Click"/>
                    <Button x:Name="NavInbox" Style="{StaticResource Nav}" Content="📥   Capture inbox" Click="NavInbox_Click"/>

                    <Button Style="{StaticResource Primary}" Content="＋  Add deadline" Margin="4,20,4,0" Click="Add_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                    <Button x:Name="NavSettings" Style="{StaticResource Nav}" Content="⚙   Settings" Click="NavSettings_Click"/>
                    <Border Background="{StaticResource Surface2}" CornerRadius="8" Padding="10,8" Margin="0,10,0,0">
                        <TextBlock x:Name="AutoStartLabel" Foreground="{StaticResource Muted}" FontSize="11"
                                   TextWrapping="Wrap" Text="Runs in the background. Closing the window keeps it alive in the tray."/>
                    </Border>
                </StackPanel>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ContentControl x:Name="MainContent" Grid.Column="1"/>
    </Grid>
</Window>
